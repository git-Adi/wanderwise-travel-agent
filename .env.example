# --- HuggingFace (open-source model via InferenceClient) ---
HF_TOKEN=hf-...

# --- Exa (web search / blogs / news / visitor posts) ---
EXA_API_KEY=exa-...

# --- Model selection ---
# Default agent model. Qwen2.5-72B-Instruct has 128k context and strong tool-use support.
TRAVEL_AGENT_MODEL=Qwen/Qwen2.5-72B-Instruct

# --- Google Drive (saving the prompt templates) ---
# OAuth "installed app" client secret downloaded from Google Cloud Console.
GDRIVE_CREDENTIALS=credentials.json
# Where the cached OAuth token is stored after the first sign-in.
GDRIVE_TOKEN=token.json
# Optional: a Drive folder ID to save templates into (leave blank for My Drive root).
GDRIVE_FOLDER_ID=
